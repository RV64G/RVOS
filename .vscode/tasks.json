{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "stop-qemu",
            "type": "shell",
            "command": "killall qemu-system-riscv64 || true"
        },
        {
            "label": "Build",
            "type": "shell",
            "command": "make",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Generate Compile Commands",
            "type": "shell",
            "command": "make compile-commands",
            "problemMatcher": []
        },
        {
            "label": "Build ESP",
            "type": "shell",
            "command": "make efi-esp"
        },
        {
            "label": "Run",
            "type": "shell",
            "command": "make run",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Build ESP"
            ],
            "problemMatcher": []
        },
        {
            "label": "Start OpenOCD",
            "type": "shell",
            "command": "openocd",
            "args": [
                "-f",
                "mars_jtag.cfg"
            ],
            "group": "build",
            "isBackground": true,
            "problemMatcher": {
                "pattern": {
                    "regexp": "^(.*)$",
                    "file": 1
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^Open On-Chip Debugger",
                    "endsPattern": "Listening on port 3333 for gdb connections"
                }
            }
        },
        {
            "label": "Stop OpenOCD",
            "type": "shell",
            "command": "pkill",
            "args": [
                "-f",
                "openocd"
            ]
        }
    ]
}
